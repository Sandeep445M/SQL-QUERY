SELECT
	r.start_time, r.session_id, r.blocking_session_id AS blk_by, r.status,
	login_name, r.command, r.cpu_time, DB_NAME(r.database_id) DBname,
	CAST(((DATEDIFF(s,start_time,GetDate()))/3600) as varchar) + ' hour(s), ' +
	CAST((DATEDIFF(s,start_time,GetDate())%3600)/60 as varchar) + 'min, '  +
	CAST((DATEDIFF(s,start_time,GetDate())%60) as varchar) + ' sec' as running_time,
	r.percent_complete, s.host_name, s.program_name, r.wait_type, r.wait_time / (1000.0)'Wait Sec',
	'"'+Substring(st.TEXT,(r.statement_start_offset / 2) + 1, ((CASE r.statement_end_offset WHEN -1
	THEN Datalength(st.TEXT) ELSE r.statement_end_offset END - r.statement_start_offset) / 2) + 1)+
	'"' AS statement_text, ib.event_info --qp.query_plan
FROM sys.dm_exec_requests r
	INNER JOIN sys.dm_exec_sessions s ON s.session_id = r.session_id
	CROSS APPLY sys.dm_exec_input_buffer(r.session_id, r.request_id) ib
	CROSS APPLY sys.dm_exec_sql_text(sql_handle) st
	--CROSS APPLY sys.dm_exec_query_plan(r.plan_handle) qp
WHERE s.session_id>50 AND r.session_id<>@@SPID
ORDER BY r.cpu_time desc
GO
